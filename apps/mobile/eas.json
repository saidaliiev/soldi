{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk"
      },
      "channel": "development",
      "env": {
        "APP_VARIANT": "development",
        "EXPO_PUBLIC_ENV": "development"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk"
      },
      "channel": "preview",
      "env": {
        "APP_VARIANT": "preview",
        "EXPO_PUBLIC_ENV": "preview"
      }
    },
    "testflight": {
      "autoIncrement": true,
      "distribution": "store",
      "ios": {
        "resourceClass": "m-medium"
      },
      "channel": "testflight",
      "env": {
        "APP_VARIANT": "production",
        "EXPO_PUBLIC_ENV": "production"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "resourceClass": "m-medium"
      },
      "channel": "production",
      "env": {
        "APP_VARIANT": "production",
        "EXPO_PUBLIC_ENV": "production"
      }
    }
  },
  "submit": {
    "testflight": {
      "ios": {
        "appleId": "REPLACE_WITH_APPLE_ID_BEFORE_SUBMIT",
        "ascAppId": "REPLACE_WITH_ASC_APP_ID_BEFORE_SUBMIT",
        "appleTeamId": "REPLACE_WITH_APPLE_TEAM_ID_BEFORE_SUBMIT"
      }
    },
    "production": {
      "ios": {
        "appleId": "REPLACE_WITH_APPLE_ID_BEFORE_SUBMIT",
        "ascAppId": "REPLACE_WITH_ASC_APP_ID_BEFORE_SUBMIT",
        "appleTeamId": "REPLACE_WITH_APPLE_TEAM_ID_BEFORE_SUBMIT"
      }
    }
  }
}
